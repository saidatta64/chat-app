# Server environment variables
# Copy to `.env` and fill in your values.

PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/edu-app

# CORS (optional in dev)
FRONTEND_URL=
CLIENT_URL=

# ── Redis ────────────────────────────────────────────────────────────────────
# Option A (recommended): single connection URL — works with Upstash, Redis Cloud, etc.
# REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:6379
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6380

# Option B: individual fields
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# Optional namespace prefix for all Redis keys (default: chat-app)
REDIS_KEY_PREFIX=chat-app
